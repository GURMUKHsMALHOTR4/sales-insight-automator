# Copy to .env and fill in. Do not commit .env.

# Resend (https://resend.com) - required to send summary emails
RESEND_API_KEY=your_resend_api_key_here

# Optional: CORS origins (comma-separated). Default: http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Optional: Ollama for AI summaries (leave unset to use mock summary)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
